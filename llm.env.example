# LLM Configuration (non-hidden, safe to commit)
# Copy to .env or merge into your existing .env

# Backend selection: true = local, false = cloud
USE_LOCAL_LLM=true

# Local LLM (TinyLlama + LoRA)
LOCAL_LLM_BASE_MODEL=TinyLlama/TinyLlama-1.1B-Chat-v1.0
LOCAL_LLM_LORA_PATH=models/tinyllama-lora-qa
LOCAL_LLM_DEVICE=auto

# Shared LLM settings
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# RAG settings (used by local LLM)
RAG_ENABLED=true
RAG_TOP_K=5
RAG_MAX_CONTEXT_TOKENS=1000
RAG_CUSTOM_PATH=
RAG_CUSTOM_EXTS=md,txt,feature,py,java,js,ts,tsx,jsx,json,yaml,yml
RAG_CUSTOM_MAX_BYTES=1000000
